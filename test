<script>
// ── Document type dropdown handler ────────────────────────────────────────
function handleDocTypeChange(val) {
  var isForm   = val === 'Form';
  var contentCard  = document.getElementById('contentCard');
  var formPanel    = document.getElementById('formTypePanel');

  if (isForm) {
    // Hide the generic content card, show the form panel
    contentCard.classList.add('d-none');
    formPanel.classList.remove('d-none');
  } else {
    // Show generic content card, hide form panel
    contentCard.classList.remove('d-none');
    formPanel.classList.add('d-none');
  }
  updateDocIdPreview();
}

// ── Form mode tabs (Build / Upload) ───────────────────────────────────────
function switchFormMode(mode) {
  var buildEl  = document.getElementById('formBuildMode');
  var uploadEl = document.getElementById('formUploadMode');
  var tabB     = document.getElementById('tabBuild');
  var tabU     = document.getElementById('tabUpload');

  if (mode === 'build') {
    buildEl.classList.remove('d-none');
    uploadEl.classList.add('d-none');
    tabB.classList.add('active');
    tabU.classList.remove('active');
  } else {
    uploadEl.classList.remove('d-none');
    buildEl.classList.add('d-none');
    tabU.classList.add('active');
    tabB.classList.remove('active');
  }
}

// ── Pass document context to form-builder ─────────────────────────────────
document.getElementById('openBuilderBtn').addEventListener('click', function(e) {
  // Store current doc context so form-builder can return here
  var ctx = {
    docType:   document.getElementById('docTypeSelect').value,
    docNumber: document.getElementById('docNumber').value,
    docTopic:  document.getElementById('docTopic').value,
  };
  sessionStorage.setItem('cpFormBuilderContext', JSON.stringify(ctx));
  // Link href already points to form-builder.html — allow navigation
});

// ── Remove attached form ───────────────────────────────────────────────────
function detachForm() {
  sessionStorage.removeItem('cpBuiltForm');
  document.getElementById('attachedFormSummary').classList.add('d-none');
  document.getElementById('noFormAttached').classList.remove('d-none');
  document.getElementById('formReturnBanner').classList.add('d-none');
}

// ── Document ID live preview ───────────────────────────────────────────────
function updateDocIdPreview() {
  var type    = document.getElementById('docTypeSelect').value || 'SOP';
  var number  = document.getElementById('docNumber').value     || '000';
  var topic   = document.getElementById('docTopic').value      || 'Topic';
  var version = '01';
  document.getElementById('docIdPreview').textContent =
    type + '-' + number + '-' + topic + '-' + version;
}

document.getElementById('docTopic').addEventListener('input', updateDocIdPreview);
document.getElementById('docNumber').addEventListener('input', updateDocIdPreview);

// ── Read form data passed back from form-builder ───────────────────────────
(function restoreBuiltForm() {
  var raw = sessionStorage.getItem('cpBuiltForm');
  if (!raw) return;

  try {
    var data = JSON.parse(raw);

    // Switch doc type selector to Form (if not already)
    var sel = document.getElementById('docTypeSelect');
    sel.value = 'Form';
    handleDocTypeChange('Form');

    // Show the attached summary
    var fieldCount  = data.fields ? data.fields.length : 0;
    var sectionCount = data.sections ? data.sections.length : 0;

    document.getElementById('attachedFormName').textContent = data.formName || 'Untitled Form';
    document.getElementById('attachedFormMeta').textContent =
      fieldCount + ' field' + (fieldCount !== 1 ? 's' : '') +
      (sectionCount > 1 ? ', ' + sectionCount + ' sections' : '') +
      ' · Built ' + new Date().toLocaleDateString('en-GB', { day:'numeric', month:'short', year:'numeric' });

    document.getElementById('attachedFormSummary').classList.remove('d-none');
    document.getElementById('noFormAttached').classList.add('d-none');

    // Edit link — go back to builder with existing data
    document.getElementById('editFormLink').href = 'form-builder.html?edit=1';

    // Show return banner
    var banner = document.getElementById('formReturnBanner');
    var msg    = document.getElementById('formReturnMsg');
    msg.textContent = '"' + (data.formName || 'Untitled Form') + '" attached — ' +
                      fieldCount + ' field' + (fieldCount !== 1 ? 's' : '') + ' ready.';
    banner.classList.remove('d-none');

  } catch(e) {
    console.warn('Could not restore built form:', e);
  }
})();
</script>
</body>
