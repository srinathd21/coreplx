<script>
var DOCS = [
  { id:'SOP-104-CAPA-V3',       title:'CAPA Management',              type:'SOP',     ver:'V3', dept:'Quality Assurance',      owner:'Pradeep',   effective:'2026-01-15', review:'2028-01-15', overdue:false },
  { id:'SOP-021-Training-V1',   title:'Training Procedure',           type:'SOP',     ver:'V1', dept:'Human Resources',        owner:'Ariharan',  effective:'2026-03-01', review:'2028-03-01', overdue:false },
  { id:'SOP-007-DevControl-V2', title:'Deviation Control',            type:'SOP',     ver:'V2', dept:'Operations',             owner:'Kavin',     effective:'2025-11-10', review:'2025-10-10', overdue:true  },
  { id:'POL-004-Quality-V2',    title:'Quality Policy',               type:'Policy',  ver:'V2', dept:'Quality Assurance',      owner:'Kavin',     effective:'2026-01-15', review:'2028-01-15', overdue:false },
  { id:'POL-011-DataInt-V1',    title:'Data Integrity Policy',        type:'Policy',  ver:'V1', dept:'Information Technology', owner:'Pradeep',   effective:'2025-09-01', review:'2025-09-01', overdue:true  },
  { id:'POL-021-Security-V2',   title:'Information Security Policy',  type:'Policy',  ver:'V2', dept:'Information Technology', owner:'Anita Rao', effective:'2025-08-15', review:'2025-08-15', overdue:true  },
  { id:'GUI-003-CAPA-V1',       title:'CAPA Workflow Guidance',       type:'Guidance',ver:'V1', dept:'Quality Assurance',      owner:'Ariharan',  effective:'2026-02-01', review:'2028-02-01', overdue:false },
  { id:'GUI-008-Audit-V2',      title:'Internal Audit Guidance',      type:'Guidance',ver:'V2', dept:'Quality Assurance',      owner:'Deepa',     effective:'2025-10-20', review:'2025-10-20', overdue:true  },
  { id:'GUI-089-DMS-V4',        title:'DMS Access Guidance',          type:'Guidance',ver:'V4', dept:'Information Technology', owner:'Pradeep',   effective:'2026-02-09', review:'2027-02-09', overdue:false },
  { id:'FRM-010-Inspection-V3', title:'Inspection Form',              type:'Form',    ver:'V3', dept:'Operations',             owner:'Priya',     effective:'2025-11-20', review:'2025-11-20', overdue:true  },
  { id:'FRM-015-Training-V1',   title:'Training Acknowledgement',     type:'Form',    ver:'V1', dept:'Human Resources',        owner:'Ariharan',  effective:'2026-03-10', review:'2028-03-10', overdue:false },
];

function applyFilters() {
  var q      = document.getElementById('repoSearch').value.toLowerCase();
  var type   = document.getElementById('repoType').value;
  var dept   = document.getElementById('repoDept').value;
  var review = document.getElementById('repoReview').value;

  var filtered = DOCS.filter(function(d) {
    return (!q      || d.id.toLowerCase().includes(q) || d.title.toLowerCase().includes(q)) &&
           (!type   || d.type === type) &&
           (!dept   || d.dept === dept) &&
           (!review || (review === 'overdue' ? d.overdue : !d.overdue));
  });
  renderTable(filtered);
}

function resetFilters() {
  document.getElementById('repoSearch').value = '';
  document.getElementById('repoType').value   = '';
  document.getElementById('repoDept').value   = '';
  document.getElementById('repoReview').value = '';
  renderTable(DOCS);
}

function renderTable(data) {
  var body  = document.getElementById('repoBody');
  var empty = document.getElementById('repoEmpty');
  var count = document.getElementById('repoCount');

  count.textContent = 'Showing ' + data.length + ' of ' + DOCS.length + ' documents';

  if (!data.length) { body.innerHTML = ''; empty.classList.remove('d-none'); return; }
  empty.classList.add('d-none');

  body.innerHTML = data.map(function(d) {
    var reviewColor = d.overdue ? 'color:#dc2626;font-weight:600;' : 'color:#6b7280;';
    var statusBadge = d.overdue
      ? '<span class="badge badge-soft-danger">Overdue Review</span>'
      : '<span class="badge badge-soft-success">Effective</span>';
    return '<tr>' +
      '<td class="fw-semibold" style="color:#2563eb;font-size:13px;">' + d.id + '</td>' +
      '<td style="font-size:13px;">' + d.title + '</td>' +
      '<td><span class="badge badge-soft-info">' + d.type + '</span></td>' +
      '<td style="font-size:13px;">' + d.ver + '</td>' +
      '<td style="font-size:12px;color:#6b7280;">' + d.dept + '</td>' +
      '<td style="font-size:12px;color:#6b7280;">' + d.owner + '</td>' +
      '<td style="font-size:12px;color:#6b7280;">' + fmt(d.effective) + '</td>' +
      '<td style="font-size:12px;' + reviewColor + '">' + fmt(d.review) + '</td>' +
      '<td>' + statusBadge + '</td>' +
      '<td style="white-space:nowrap;">' +
        '<button class="btn btn-sm btn-outline-primary"   style="height:28px;padding:0 10px;font-size:12px;">View</button>&nbsp;' +
        '<button class="btn btn-sm btn-outline-secondary" style="height:28px;padding:0 10px;font-size:12px;">&#11015; PDF</button>' +
      '</td>' +
    '</tr>';
  }).join('');
}

function fmt(s) {
  if (!s) return '—';
  return new Date(s).toLocaleDateString('en-GB', {day:'numeric',month:'short',year:'numeric'});
}

renderTable(DOCS);
</script>
</body>
