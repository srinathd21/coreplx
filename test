<script>
// ── Sample data — replace with PHP echo of JSON from DB ───────────────────
// Structure: { TYPE: [ {id, topic, number, version, owner, effectiveDate, reviewDate} ] }
var EFFECTIVE_DOCS = {
  SOP: [
    { id: 'SOP-021-Training-V1',      topic: 'Training Procedure',          number: '021', version: 'V1', owner: 'Ariharan',  effectiveDate: '2026-03-01', reviewDate: '2028-03-01' },
    { id: 'SOP-104-CAPA-V3',          topic: 'CAPA Management',             number: '104', version: 'V3', owner: 'Pradeep',   effectiveDate: '2026-01-15', reviewDate: '2028-01-15' },
    { id: 'SOP-007-DevControl-V2',    topic: 'Deviation Control',           number: '007', version: 'V2', owner: 'Kavin',     effectiveDate: '2025-11-10', reviewDate: '2027-11-10' },
  ],
  Policy: [
    { id: 'POL-004-Quality-V2',       topic: 'Quality Policy',              number: '004', version: 'V2', owner: 'Kavin',     effectiveDate: '2026-01-15', reviewDate: '2028-01-15' },
    { id: 'POL-011-DataIntegrity-V1', topic: 'Data Integrity Policy',       number: '011', version: 'V1', owner: 'Pradeep',   effectiveDate: '2025-09-01', reviewDate: '2027-09-01' },
  ],
  Guidance: [
    { id: 'GUI-003-CAPA-V1',          topic: 'CAPA Workflow Guidance',      number: '003', version: 'V1', owner: 'Ariharan',  effectiveDate: '2026-02-01', reviewDate: '2028-02-01' },
    { id: 'GUI-008-Audit-V2',         topic: 'Internal Audit Guidance',     number: '008', version: 'V2', owner: 'Deepa',     effectiveDate: '2025-10-20', reviewDate: '2027-10-20' },
  ],
  Form: [
    { id: 'FRM-010-Inspection-V3',    topic: 'Inspection Form',             number: '010', version: 'V3', owner: 'Priya',     effectiveDate: '2025-11-20', reviewDate: '2027-11-20' },
    { id: 'FRM-015-Training-V1',      topic: 'Training Acknowledgement',    number: '015', version: 'V1', owner: 'Ariharan',  effectiveDate: '2026-03-10', reviewDate: '2028-03-10' },
  ]
};

// ── Step 1: Type selected → populate document dropdown ────────────────────
function onTypeChange(type) {
  var docSel  = document.getElementById('docSelect');
  var hint    = document.getElementById('docSelectHint');

  // Reset downstream
  resetDocDetails();

  if (!type) {
    docSel.disabled = true;
    docSel.innerHTML = '<option value="">-- Select Type first --</option>';
    hint.textContent = 'Choose a document type above to populate this list.';
    return;
  }

  var docs = EFFECTIVE_DOCS[type] || [];
  docSel.innerHTML = '<option value="">-- Select a ' + type + ' document --</option>';
  docs.forEach(function(doc) {
    var opt = document.createElement('option');
    opt.value = doc.id;
    opt.textContent = doc.id + '  —  ' + doc.topic;
    docSel.appendChild(opt);
  });

  docSel.disabled = false;
  hint.textContent = docs.length + ' effective ' + type + ' document' + (docs.length !== 1 ? 's' : '') + ' available.';
}

// ── Step 2: Document selected → auto-fill all fields ─────────────────────
function onDocSelect(docId) {
  resetDocDetails();
  if (!docId) return;

  var type = document.getElementById('docTypeSelect').value;
  var docs = EFFECTIVE_DOCS[type] || [];
  var doc  = docs.find(function(d) { return d.id === docId; });
  if (!doc) return;

  // Calculate next version
  var newVersion = incrementVersion(doc.version);

  // Show info strip
  var panel = document.getElementById('docInfoPanel');
  document.getElementById('diId').textContent   = doc.id;
  document.getElementById('diMeta').textContent =
    'Topic: ' + doc.topic +
    '  ·  Owner: ' + doc.owner +
    '  ·  Effective: ' + formatDate(doc.effectiveDate);
  panel.classList.remove('d-none');

  // Fill fields
  document.getElementById('fDocId').value        = doc.id;
  document.getElementById('fDocTopic').value      = doc.topic;
  document.getElementById('fCurrentVersion').value = doc.version;
  document.getElementById('fNewVersion').value    = newVersion;

  // Version visual strip
  document.getElementById('vsCurrentBadge').textContent = doc.version;
  document.getElementById('vsNewBadge').textContent      = newVersion;

  // Owner
  setSelectValue('fOwner', doc.owner);

  // Dates — pre-fill effective with today, review with +2 years
  var today = new Date();
  document.getElementById('fEffectiveDate').value = toInputDate(today);
  var reviewDate = new Date(today);
  reviewDate.setFullYear(reviewDate.getFullYear() + 2);
  document.getElementById('fReviewDate').value = toInputDate(reviewDate);

  // Show detail cards
  document.getElementById('docDetailsCard').classList.remove('d-none');
  document.getElementById('contentCard').classList.remove('d-none');
}

// ── Reset when type or doc changes ────────────────────────────────────────
function resetDocDetails() {
  document.getElementById('docInfoPanel').classList.add('d-none');
  document.getElementById('docDetailsCard').classList.add('d-none');
  document.getElementById('contentCard').classList.add('d-none');
  ['fDocId','fDocTopic','fCurrentVersion','fNewVersion',
   'fEffectiveDate','fReviewDate','fChangeSummary'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.value = '';
  });
  document.getElementById('vsCurrentBadge').textContent = '—';
  document.getElementById('vsNewBadge').textContent      = '—';
}

// ── Version increment logic ────────────────────────────────────────────────
// Handles V1→V2, V3→V4, V09→V10, etc.
function incrementVersion(ver) {
  var match = ver.match(/^([A-Za-z]*)(\d+)$/);
  if (!match) return ver + '-Rev2';
  var prefix = match[1];
  var num    = parseInt(match[2], 10);
  var newNum = num + 1;
  // Preserve zero-padding if original had it (e.g. V01→V02)
  var padded = match[2].length > 1
    ? String(newNum).padStart(match[2].length, '0')
    : String(newNum);
  return prefix + padded;
}

// ── Helpers ───────────────────────────────────────────────────────────────
function setSelectValue(id, value) {
  var sel = document.getElementById(id);
  for (var i = 0; i < sel.options.length; i++) {
    if (sel.options[i].text === value || sel.options[i].value === value) {
      sel.selectedIndex = i;
      return;
    }
  }
}

function toInputDate(d) {
  return d.getFullYear() + '-' +
    String(d.getMonth() + 1).padStart(2, '0') + '-' +
    String(d.getDate()).padStart(2, '0');
}

function formatDate(str) {
  if (!str) return '—';
  var d = new Date(str);
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}
